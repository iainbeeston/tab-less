{
  "name": "tab-less",
  "description": "Disables tabs for tab-less browsing",
  "version": "0.7.0",
  "license": "LGPL-3.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git://github.com/iainbeeston/tab-less.git"
  },
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "build:edge": "wxt build -b edge",
    "build:safari": "wxt build -b safari",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "zip:edge": "wxt zip -b edge",
    "analyze": "wxt build --analyze",
    "submit": "tsx scripts/submit.ts",
    "submit:init": "wxt submit init",
    "compile": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "promo": "tsx scripts/promo.ts",
    "clean": "wxt clean",
    "postinstall": "wxt prepare"
  },
  "devDependencies": {
    "@eslint/js": "^9.31.0",
    "@types/node": "^22.20.0",
    "@vitest/eslint-plugin": "^1.6.20",
    "@wxt-dev/auto-icons": "^1.1.1",
    "eslint": "^9.31.0",
    "eslint-plugin-unicorn": "^60.0.0",
    "globals": "^15.15.0",
    "jiti": "^2.7.0",
    "sharp": "^0.34.5",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.1",
    "vitest": "^3.2.6",
    "wxt": "^0.20.26"
  }
}
